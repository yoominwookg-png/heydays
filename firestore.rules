rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && (request.auth.token.email_verified == true || request.auth.token.firebase.sign_in_provider == 'password');
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9._\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 1. Users
    match /users/{userId} {
      function isValidUser(data) {
        return data.id is string && data.id.size() <= 128 &&
               data.name is string && data.name.size() <= 100 &&
               data.name.size() > 0 &&
               data.role in ['admin', 'member'] &&
               data.createdAt is number &&
               (!('avatar' in data) || data.avatar is string) &&
               (!('bio' in data) || data.bio is string) &&
               (!('deletedAt' in data) || data.deletedAt is number) &&
               (!('lastActiveAt' in data) || data.lastActiveAt is number);
      }

      allow get: if isSignedIn() && isValidId(userId);
      allow list: if isSignedIn(); // Band members can see the directory
      // Allow sign-in level access for initial profile creation to avoid verification bridge problem
      allow create: if isSignedIn() && isOwner(userId) && 
                      isValidUser(incoming()) && 
                      isValidId(userId);
      allow update: if (isVerified() || isAdmin()) && isValidId(userId) && (
                      (isOwner(userId) && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'avatar', 'bio', 'deletedAt', 'lastActiveAt']) && isValidUser(incoming())) ||
                      (isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['role', 'deletedAt', 'lastActiveAt']) && isValidUser(incoming()))
                    );
      allow delete: if isVerified() && isValidId(userId) && isAdmin();
    }
    
    // Explicit Admin markers to avoid recursive loops in isAdmin() helper if needed
    // But usually get() is fine. Let's use a separate collection for admin UIDs for efficiency.
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; // Managed via console
    }

    // 2. Posts
    match /posts/{postId} {
      function isValidPost(data) {
        return data.id is string && data.type in ['notice', 'review'] &&
               data.title is string && data.title.size() <= 200 &&
               data.content is string && data.content.size() <= 20000 &&
               data.authorId is string &&
               data.authorName is string &&
               data.createdAt is number &&
               data.likes is number &&
               data.views is number &&
               (!('files' in data) || data.files is list || data.files == null) &&
               (!('fileData' in data) || data.fileData is string || data.fileData == null) &&
               (!('commentCount' in data) || data.commentCount is number || data.commentCount == null) &&
               (!('isPinned' in data) || data.isPinned is bool || data.isPinned == null);
      }

      allow read: if isSignedIn() && isValidId(postId);
      allow list: if isSignedIn(); 
      allow create: if (isVerified() || isAdmin()) && isValidId(postId) && isValidPost(incoming()) && 
                      incoming().authorId == request.auth.uid &&
                      (incoming().type == 'notice' ? isAdmin() : true);
      allow update: if (isVerified() || isAdmin()) && isValidId(postId) && (
                      (isOwner(existing().authorId) && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'content', 'files', 'fileData', 'commentCount', 'isPinned', 'authorName']) && isValidPost(incoming())) ||
                      (incoming().diff(existing()).affectedKeys().hasOnly(['likes']) && (incoming().likes == existing().get('likes', 0) + 1 || (incoming().likes == existing().get('likes', 0) - 1 && existing().get('likes', 0) > 0))) ||
                      (incoming().diff(existing()).affectedKeys().hasOnly(['views']) && incoming().views == existing().get('views', 0) + 1) ||
                      (incoming().diff(existing()).affectedKeys().hasOnly(['commentCount']) && incoming().commentCount is number) ||
                      isAdmin()
                    );
      allow delete: if (isSignedIn() || isAdmin()) && isValidId(postId) && (isOwner(existing().authorId) || isAdmin());
    }

    match /posts/{postId}/likes/{userId} {
      allow read: if isSignedIn();
      allow create: if isVerified() && isOwner(userId) && incoming().keys().hasAll(['at']) && incoming().at is number;
      allow delete: if isVerified() && isOwner(userId);
    }

    // 3. Comments
    match /posts/{postId}/comments/{commentId} {
      function isValidComment(data) {
        return data.id is string && data.postId == postId &&
               data.authorId is string &&
               data.authorName is string &&
               data.content is string && data.content.size() <= 2000 &&
               data.createdAt is number;
      }

      allow read: if isSignedIn() && isValidId(postId) && isValidId(commentId);
      allow list: if isSignedIn() && isValidId(postId);
      allow create: if isVerified() && incoming().authorId == request.auth.uid;
      allow delete: if isVerified() && isValidId(postId) && isValidId(commentId) && 
                      (isOwner(existing().authorId) || isAdmin());
    }

    // 4. Schedules
    match /schedules/{scheduleId} {
      function isValidSchedule(data) {
        return data.id is string && data.title is string && data.title.size() <= 200 &&
               data.date is string && data.location is string &&
               data.description is string &&
               data.authorId is string &&
               data.createdAt is number &&
               (!('files' in data) || data.files is list || data.files == null) &&
               (!('mapQuery' in data) || data.mapQuery is string || data.mapQuery == null) &&
               (!('likes' in data) || data.likes is number || data.likes == null) &&
               (!('views' in data) || data.views is number || data.views == null) &&
               (!('commentCount' in data) || data.commentCount is number || data.commentCount == null);
      }

      allow read: if isSignedIn() && isValidId(scheduleId);
      allow list: if isSignedIn();
      allow create: if (isVerified() || isAdmin()) && isAdmin() && isValidId(scheduleId) && 
                      isValidSchedule(incoming()) && incoming().authorId == request.auth.uid;
      allow update: if (isVerified() || isAdmin()) && isValidId(scheduleId) && (
                      (isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'date', 'location', 'description', 'files', 'mapQuery']) && isValidSchedule(incoming())) ||
                      (incoming().diff(existing()).affectedKeys().hasOnly(['likes']) && (incoming().likes == existing().get('likes', 0) + 1 || (incoming().likes == existing().get('likes', 0) - 1 && existing().get('likes', 0) > 0))) ||
                      (incoming().diff(existing()).affectedKeys().hasOnly(['views']) && incoming().views == existing().get('views', 0) + 1) ||
                      (incoming().diff(existing()).affectedKeys().hasOnly(['commentCount']) && incoming().commentCount is number)
                    );
      allow delete: if (isVerified() || isAdmin()) && isAdmin() && isValidId(scheduleId);
    }

    match /schedules/{scheduleId}/likes/{userId} {
      allow read: if isSignedIn();
      allow create: if isVerified() && isOwner(userId) && incoming().keys().hasAll(['at']) && incoming().at is number;
      allow delete: if isVerified() && isOwner(userId);
    }

    match /schedules/{scheduleId}/comments/{commentId} {
      function isValidComment(data) {
        return data.id is string &&
               data.authorId is string &&
               data.authorName is string &&
               data.content is string && data.content.size() <= 2000 &&
               data.createdAt is number;
      }
      allow read, list: if isSignedIn() && isValidId(scheduleId);
      allow create: if isVerified() && incoming().authorId == request.auth.uid;
      allow delete: if isVerified() && (isOwner(existing().authorId) || isAdmin());
    }

    // 5. Scores
    match /scores/{scoreId} {
      function isValidScore(data) {
        return data.id is string && data.title is string && data.title.size() <= 200 &&
               data.fileType in ['pdf', 'jpg', 'png'] &&
               data.authorId is string &&
               data.createdAt is number &&
               (!('artist' in data) || data.artist is string || data.artist == null) &&
               (!('description' in data) || data.description is string || data.description == null) &&
               (!('fileData' in data) || data.fileData is string || data.fileData == null) &&
               (!('files' in data) || data.files is list || data.files == null) &&
               (!('musicVideoId' in data) || data.musicVideoId is string || data.musicVideoId == null) &&
               (!('musicThumbnail' in data) || data.musicThumbnail is string || data.musicThumbnail == null) &&
               (!('musicTitle' in data) || data.musicTitle is string || data.musicTitle == null) &&
               (!('likes' in data) || data.likes is number || data.likes == null) &&
               (!('views' in data) || data.views is number || data.views == null) &&
               (!('commentCount' in data) || data.commentCount is number || data.commentCount == null);
      }

      allow read: if isSignedIn() && isValidId(scoreId);
      allow list: if isSignedIn();
      allow create: if (isVerified() || isAdmin()) && isValidScore(incoming()) && 
                      incoming().authorId == request.auth.uid && 
                      isValidId(scoreId);
      allow update: if (isVerified() || isAdmin()) && isValidId(scoreId) && (
                      (isOwner(existing().authorId) && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'artist', 'description', 'fileData', 'files', 'musicVideoId', 'musicThumbnail', 'musicTitle']) && isValidScore(incoming())) ||
                      (incoming().diff(existing()).affectedKeys().hasOnly(['likes']) && (incoming().likes == existing().get('likes', 0) + 1 || (incoming().likes == existing().get('likes', 0) - 1 && existing().get('likes', 0) > 0))) ||
                      (incoming().diff(existing()).affectedKeys().hasOnly(['views']) && incoming().views == existing().get('views', 0) + 1) ||
                      (incoming().diff(existing()).affectedKeys().hasOnly(['commentCount']) && incoming().commentCount is number) ||
                      isAdmin()
                    );
      allow delete: if (isVerified() || isAdmin()) && (isOwner(existing().authorId) || isAdmin()) && isValidId(scoreId);
    }

    match /scores/{scoreId}/likes/{userId} {
      allow read: if isSignedIn();
      allow create: if isVerified() && isOwner(userId) && incoming().keys().hasAll(['at']) && incoming().at is number;
      allow delete: if isVerified() && isOwner(userId);
    }

    match /scores/{scoreId}/comments/{commentId} {
      function isValidComment(data) {
        return data.id is string &&
               data.authorId is string &&
               data.authorName is string &&
               data.content is string && data.content.size() <= 2000 &&
               data.createdAt is number;
      }
      allow read, list: if isSignedIn() && isValidId(scoreId);
      allow create: if isVerified() && incoming().authorId == request.auth.uid;
      allow delete: if isVerified() && (isOwner(existing().authorId) || isAdmin());
    }

    // 6. Score Notes
    match /scores/{scoreId}/notes/{noteId} {
      function isValidNote(data) {
        return data.id is string && data.scoreId == scoreId &&
               data.authorId == request.auth.uid &&
               data.content is string && data.content.size() <= 2000 &&
               data.updatedAt is number;
      }

      allow read: if isSignedIn() && isOwner(noteId); // noteId is userId
      allow write: if isVerified() && isOwner(noteId) && isValidNote(incoming());
    }

    // 7. Messages
    match /messages/{messageId} {
      function isValidMessage(data) {
        return data.senderId == request.auth.uid &&
               data.content is string && data.content.size() <= 5000 &&
               data.createdAt is number;
      }

      allow create: if isVerified() && isValidId(messageId) && isValidMessage(incoming());
      allow update: if isVerified() && isValidId(messageId) && isOwner(existing().receiverId) && 
                      incoming().diff(existing()).affectedKeys().hasOnly(['isRead']);
      allow delete: if isVerified() && isValidId(messageId) && (isOwner(existing().senderId) || isOwner(existing().receiverId) || isAdmin());
      allow list: if isSignedIn() && (resource.data.senderId == request.auth.uid || resource.data.receiverId == request.auth.uid);
    }

    // 8. Notifications
    match /notifications/{notificationId} {
      allow get: if isSignedIn() && (
                    isValidId(notificationId) && (
                      resource == null || 
                      isOwner(existing().userId) ||
                      (existing().type == 'chat_invite' && existing().meta.inviterId == request.auth.uid) ||
                      existing().userId == 'all'
                    )
                  );
      allow list: if isSignedIn() && resource.data.userId in [request.auth.uid, 'all'];
      allow update: if isSignedIn() && isValidId(notificationId) && (
                      (isOwner(existing().userId) && incoming().diff(existing()).affectedKeys().hasOnly(['isRead'])) ||
                      (existing().type == 'chat_invite' && (existing().meta.inviterId == request.auth.uid || existing().userId == request.auth.uid)) ||
                      isAdmin()
                    );
      allow create: if isSignedIn() && isValidId(notificationId) && (
                      (incoming().userId == 'all' && isAdmin()) ||
                      (incoming().type == 'chat_invite' && (incoming().meta.inviterId == request.auth.uid || incoming().userId == request.auth.uid)) ||
                      (incoming().userId == request.auth.uid) // Self-notification
                    );
      allow delete: if isSignedIn() && (isAdmin() || isOwner(existing().userId)) && isValidId(notificationId);
    }

    // 9. Attachments (Direct Firestore Storage)
    match /attachments/{attachmentId} {
      function isValidAttachment(data) {
        return data.data is string && data.data.size() <= 1500000 && // Account for base64 overhead
               data.contentType is string &&
               data.size is number && data.size <= 1048576 && // 1MB raw limit
               data.userId == request.auth.uid && // Owner check
               data.createdAt is number;
      }
      
      allow get: if isSignedIn();
      allow create: if isSignedIn() && isValidAttachment(incoming());
      allow update: if false; // Attachments are immutable
      allow delete: if isVerified() && (isOwner(existing().userId) || isAdmin());
    }

    // 10. System Health Check
    match /system/health {
      allow read: if true;
    }

    // 11. Chat Rooms
    match /chatRooms/{roomId} {
      function isValidChatRoom(data) {
        return data.id is string &&
               data.participants is list && data.participants.size() >= 2 &&
               data.createdAt is number &&
               data.updatedAt is number &&
               (!('participantNames' in data) || data.participantNames is list) &&
               (!('activeParticipants' in data) || data.activeParticipants is list) &&
               (!('status' in data) || data.status in ['active', 'ended']) &&
               (!('endedAt' in data) || data.endedAt is number || data.endedAt == null) &&
               (!('lastMessage' in data) || data.lastMessage is string);
      }

      function isParticipant(data) {
        return isSignedIn() && request.auth.uid in data.participants;
      }
      
      allow get: if isSignedIn() && (
                    (roomId.matches('^direct_.*' + request.auth.uid + '.*$')) ||
                    (resource != null && isParticipant(resource.data)) ||
                    (resource != null && resource.data.get('status', 'active') == 'ended') ||
                    isAdmin()
                  );
      allow list: if (isSignedIn() && request.auth.uid in resource.data.participants) || isAdmin();
      allow create: if isSignedIn() && 
                      request.auth.uid in incoming().participants && 
                      isValidChatRoom(incoming()) &&
                      isValidId(roomId);
      allow update: if isSignedIn() && (isParticipant(existing()) || isAdmin()) && (
                      // Add new participant or update active list
                      (incoming().diff(existing()).affectedKeys().hasOnly(['participants', 'participantNames', 'activeParticipants', 'status', 'endedAt', 'updatedAt', 'lastMessage']) && 
                      isValidChatRoom(incoming())) ||
                      isAdmin()
                    );
      allow delete: if isParticipant(existing()) || isAdmin();

      match /messages/{messageId} {
        function isValidChatMessage(data) {
          return data.id is string &&
                 data.roomId == roomId &&
                 (data.senderId == request.auth.uid || data.senderId == 'system') &&
                 data.senderName is string &&
                 data.content is string && data.content.size() <= 5000 &&
                 data.createdAt is number &&
                 (!('fileUrl' in data) || data.fileUrl is string) &&
                 (!('fileName' in data) || data.fileName is string) &&
                 (!('fileType' in data) || data.fileType is string) &&
                 (!('previewUrl' in data) || data.previewUrl is string);
        }

        allow read, list: if isParticipant(get(/databases/$(database)/documents/chatRooms/$(roomId)).data) || 
                          get(/databases/$(database)/documents/chatRooms/$(roomId)).data.get('status', 'active') == 'ended' ||
                          isAdmin();
        allow create: if isSignedIn() && 
                        isParticipant(get(/databases/$(database)/documents/chatRooms/$(roomId)).data) &&
                        isValidChatMessage(incoming());
        allow delete: if isParticipant(get(/databases/$(database)/documents/chatRooms/$(roomId)).data) || isAdmin();
      }
    }
  }
}
